{
    "name": "desktop",
    "version": "0.1.0",
    "private": true,
    "main": "dist-electron/main/index.js",
    "scripts": {
        "dev": "concurrently -k \"pnpm dev:next\" \"pnpm dev:electron\"",
        "dev:next": "next dev -p 3000",
        "dev:electron": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && electron .",
        "build": "next build && tsc -p electron/tsconfig.json && electron-builder",
        "lint": "ultracite lint",
        "typecheck": "tsc --noEmit --emitDeclarationOnly false",
        "postinstall": "electron-builder install-app-deps"
    },
    "build": {
        "appId": "com.anorha.desktop",
        "productName": "Anorha",
        "directories": {
            "output": "dist"
        },
        "files": [
            "dist-electron/**/*",
            ".next/server/app/**/*",
            ".next/static/**/*",
            "public/**/*",
            "package.json"
        ],
        "mac": {
            "target": "dmg",
            "hardenedRuntime": true,
            "gatekeeperAssess": false
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        }
    },
    "dependencies": {
        "@clerk/nextjs": "^6.20.0",
        "@polar-sh/nextjs": "^0.4.9",
        "@react-spring/three": "^10.0.3",
        "@react-three/fiber": "^9.4.0",
        "@repo/analytics": "workspace:*",
        "@repo/auth": "workspace:*",
        "@repo/collaboration": "workspace:*",
        "@repo/database": "workspace:*",
        "@repo/design-system": "workspace:*",
        "@repo/feature-flags": "workspace:*",
        "@repo/next-config": "workspace:*",
        "@repo/notifications": "workspace:*",
        "@repo/observability": "workspace:*",
        "@repo/payments": "workspace:*",
        "@repo/security": "workspace:*",
        "@repo/seo": "workspace:*",
        "@repo/webhooks": "workspace:*",
        "@sentry/nextjs": "^9.22.0",
        "@shadergradient/react": "^2.4.5",
        "@supabase/ssr": "^0.7.0",
        "@supabase/supabase-js": "^2.58.0",
        "@t3-oss/env-nextjs": "^0.13.4",
        "@vercel/analytics": "^1.5.0",
        "convex": "^1.31.5",
        "fuse.js": "^7.1.0",
        "import-in-the-middle": "^1.13.2",
        "lucide-react": "^0.511.0",
        "next": "15.3.6",
        "next-themes": "^0.4.6",
        "puppeteer-core": "^24.1.1",
        "puppeteer-extra": "^3.3.6",
        "puppeteer-extra-plugin-stealth": "^2.11.2",
        "playwright-core": "^1.52.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "recharts": "^2.15.3",
        "require-in-the-middle": "^7.5.2",
        "ws": "^8.18.3",
        "sonner": "^2.0.3",
        "three": "^0.181.1",
        "zod": "^3.25.28"
    },
    "devDependencies": {
        "@repo/testing": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@shopify/cli": "^3.87.4",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.3.0",
        "@types/node": "^22.15.21",
        "@types/react": "19.1.5",
        "@types/react-dom": "19.1.5",
        "@types/three": "^0.181.0",
        "concurrently": "^9.1.2",
        "electron": "^34.0.0",
        "electron-builder": "^25.1.8",
        "jsdom": "^26.1.0",
        "tailwindcss": "^4.1.7",
        "typescript": "^5.8.3",
        "vitest": "^3.1.4",
        "wait-on": "^8.0.2"
    }
}
